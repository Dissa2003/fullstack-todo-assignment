{
  "name": "fullstack-todo-assignment",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --names \"client,server\" --prefix-colors \"cyan,yellow\" \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "start": "concurrently --names \"client,server\" --prefix-colors \"cyan,yellow\" \"npm run dev --workspace=client\" \"npm start --workspace=server\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
